# AISeekho Challenge 2 - Juggaad Backend

# GCP Project ID for Vertex AI (Gemini)
GCP_PROJECT_ID="aiseekho-service-orchestrator"
GCP_REGION="us-central1"

# Path to your Service Account JSON key (must have Vertex AI and Firestore permissions)
# Ensure the path is correct relative to where you run the server.
GOOGLE_APPLICATION_CREDENTIALS="aiseekho-service-orchestrator-38e03530d861.json"

# Google Maps API Key (Must have Distance Matrix API enabled)
MAPS_API_KEY="AIzaSyYourMapsApiKeyHere..."

# CORS origins (comma-separated, no spaces)
BACKEND_CORS_ORIGINS="*"
